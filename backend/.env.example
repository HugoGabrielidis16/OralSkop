# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
# WARNING: hackathon sandbox uses temporary session credentials
# Refresh AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_SESSION_TOKEN
# from the event portal before each session and before the demo.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_S3_REGION=us-west-2
S3_BUCKET_PHOTOS=oralskop-photos
S3_BUCKET_MASKED=oralskop-masked

# ─── AI Server ────────────────────────────────────────────────────────────────
AI_SERVER_URL=http://<ai-team-vm-ip>:<port>/analyze
USE_MOCK_AI=true

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
