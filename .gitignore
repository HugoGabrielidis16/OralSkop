# ── OralSkop (root) ─────────────────────────────────────────────
# Most build artifacts live under ai/ and are also covered by ai/.gitignore.
# These root-level patterns make the repo safe to commit from anywhere.

# Raw datasets (large; downloaded, not version-controlled)
ai/datasets/

# Processed datasets (regenerated by scripts/prepare_*.py)
ai/data/

# Training outputs / weights / experiment logs
ai/runs/
runs/
runs.zip
wandb/
*.pt
*.onnx
*.engine

# Raw dataset zips
Datasets/

# ── Python / uv ─────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.uv/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── OS / editor ─────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
