# ── OralSkop (root) ─────────────────────────────────────────────
# Most build artifacts live under ai/ and are also covered by ai/.gitignore.
# These root-level patterns make the repo safe to commit from anywhere.

# Raw datasets (large; downloaded, not version-controlled).
# Keep the folder structure + placeholder README.md files; ignore bulk data.
ai/datasets/**
!ai/datasets/**/
!ai/datasets/**/README.md

# Processed datasets (regenerated by scripts/prepare_*.py) — same treatment.
ai/data/**
!ai/data/**/
!ai/data/**/README.md

# Training outputs / weights / experiment logs
ai/runs/
wandb/
*.pt
*.onnx
*.engine

# ── Python / uv ─────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.uv/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── OS / editor ─────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
