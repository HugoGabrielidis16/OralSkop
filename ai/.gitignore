# Raw datasets (large; downloaded, not version-controlled).
# Leading slash anchors to ai/ root so these DON'T match the source package
# oralskop/data/ (an unanchored `data/` matches a `data` dir at any depth).
# Keep the folder structure + placeholder README.md files tracked, but ignore
# the bulk data inside (re-include dirs so git can descend to the READMEs).
/datasets/**
!/datasets/**/
!/datasets/**/README.md

# Processed datasets (regenerated by scripts/prepare_*.py) — same treatment.
/data/**
!/data/**/
!/data/**/README.md

# Training outputs / weights
/runs/
*.pt
*.onnx
wandb/

# Python / uv
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.uv/

# OS / editor
.DS_Store
.idea/
.vscode/
